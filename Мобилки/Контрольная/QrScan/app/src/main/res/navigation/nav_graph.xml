<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.qrscan.ui.splash.SplashFragment">
        <action
            android:id="@+id/action_splash_to_main"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_splash_to_scanner"
            app:destination="@id/qrScannerFragment" />
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/qrScannerFragment"
        android:name="com.example.qrscan.ui.scanner.QrScannerFragment">
        <action
            android:id="@+id/action_scanner_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_scanner_to_main"
            app:destination="@id/mainFragment" />
    </fragment>

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.qrscan.ui.main.MainFragment">
        <action
            android:id="@+id/action_main_to_scanner"
            app:destination="@id/qrScannerFragment"
            app:popUpTo="@id/mainFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.qrscan.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>